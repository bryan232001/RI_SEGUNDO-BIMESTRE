        "2.2 Transformo a embeddings"
      ],
      "metadata": {
        "id": "LPv_3UzCAl_S"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "import time\n",
        "import re\n",
        "import numpy as np\n",
        "from tqdm import tqdm\n",
        "\n",
        "EMBEDDING_MODEL_NAME = \"models/gemini-embedding-001\"\n",
        "\n",
        "def extraer_tiempo_espera(error_msg, default=20):\n",
        "    match = re.search(r\"retry in ([\\d.]+)s\", str(error_msg))\n",
        "    if match:\n",
        "        return float(match.group(1)) + 2  # margen extra\n",
        "    return default\n",
        "\n",
        "def embed_fn(text_list, model_name=EMBEDDING_MODEL_NAME, task_type=\"RETRIEVAL_DOCUMENT\",\n",
        "             batch_size=10, output_dim=768, max_retries=3,\n",
        "             sleep_between_batches=15, checkpoint_path=\"embeddings_checkpoint.npy\"):\n",
        "    embeddings = []\n",
        "    for i in tqdm(range(0, len(text_list), batch_size), desc=\"Generando embeddings\"):\n",
        "        batch = text_list[i:i + batch_size]\n",
        "        cleaned_batch = [text for text in batch if text and str(text).strip()]\n",
        "        if not cleaned_batch:\n",
        "            continue\n",
        "\n",
        "        for attempt in range(max_retries):\n",
        "            try:\n",
        "                response = genai.embed_content(\n",
        "                    model=model_name,\n",
        "                    content=cleaned_batch,\n",
        "                    task_type=task_type,\n",
        "                    output_dimensionality=output_dim\n",
        "                )\n",
        "                embeddings.extend([item for item in response['embedding']])\n",
        "                break\n",
        "            except Exception as e:\n",
        "                wait = extraer_tiempo_espera(e)\n",
        "                print(f\"\\n⚠️ Error en batch {i}: {e}\")\n",
        "                if attempt < max_retries - 1:\n",
        "                    print(f\"   Reintentando en {wait:.1f}s...\")\n",
        "                    time.sleep(wait)\n",
        "                else:\n",
        "                    print(\"   ❌ Se omite este batch tras agotar reintentos.\")\n",
        "\n",
        "        time.sleep(sleep_between_batches)  # pausa para respetar límite por minuto\n",
        "        np.save(checkpoint_path, np.array(embeddings))  # checkpoint tras cada batch\n",
        "\n",
        "    return np.array(embeddings)\n",
        "\n",
        "corpus_texts_20news = df_20news[\"preprocessed_text\"].tolist()\n",
        "\n",
        "print(f\"\\n⏳ Generando embeddings para {len(corpus_texts_20news)} documentos (esto tardará varios minutos)...\")\n",
        "embeddings_20news = embed_fn(corpus_texts_20news, batch_size=10, sleep_between_batches=15)\n",
        "\n",
        "print(f\"\\n✅ Embeddings generados correctamente.\")\n",
        "print(f\"   Shape de los embeddings: {embeddings_20news.shape}\")\n",
        "\n",
        "# Validar alineación con el DataFrame\n",
        "assert embeddings_20news.shape[0] == len(df_20news), \\\n",
        "    f\"❌ Desalineación: {embeddings_20news.shape[0]} embeddings vs {len(df_20news)} documentos\"\n",
        "print(\"✅ Embeddings alineados correctamente con el DataFrame\")\n",
        "\n",
        "np.save(\"20news_embeddings_gemini.npy\", embeddings_20news)\n",
        "print(\"💾 Embeddings guardados en '20news_embeddings_gemini.npy'\")"
      ],
