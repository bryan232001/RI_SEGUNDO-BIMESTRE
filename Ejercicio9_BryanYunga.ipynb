    {
      "cell_type": "markdown",
      "source": [
        "# Ejercicio 9: Uso de la API de Google Gemini"
      ],
      "metadata": {
        "id": "wuUOyTOO89CQ"
      }
    },
    {
      "cell_type": "markdown",
      "source": [
        "En este ejercicio vamos a aprender a utilizar la API de Google Gemini\n",
        "\n",
        "1. Uso básico\n",
        "\n",
        "El siguiente código sirve para conectarse con la API de Google Gemini de forma básica"
      ],
      "metadata": {
        "id": "DroZOcMw9GZH"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Instalar la librería del SDK de Google Generative AI\n",
        "!pip install -q -U google-generativeai\n",
        "\n",
        "# Importar la librería Python\n",
        "import google.generativeai as genai\n",
        "# Utilizado para almacenar de forma segura tu clave API\n",
        "from google.colab import userdata\n",
        "\n",
        "# Configurar la clave API de Google Gemini\n",
        "# Asegúrate de haber guardado tu clave en los secretos de Colab como 'GOOGLE_API_KEY'\n",
        "GOOGLE_API_KEY = userdata.get('GOOGLE_API_KEY')\n",
        "genai.configure(api_key=GOOGLE_API_KEY)\n",
        "\n",
        "# Inicializar el modelo Gemini\n",
        "gemini_model = genai.GenerativeModel('gemini-pro')\n",
        "\n",
        "print(\"✅ SDK de Google Generative AI configurado y modelo 'gemini-pro' inicializado.\")\n",
        "print(\"Ahora puedes usar 'gemini_model.generate_content()' para interactuar con Gemini.\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "0hGRmJWb9Ns2",
        "outputId": "0b58866d-124f-47ad-c119-8bf8cf18a48e"
      },
      "execution_count": 33,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "✅ SDK de Google Generative AI configurado y modelo 'gemini-pro' inicializado.\n",
            "Ahora puedes usar 'gemini_model.generate_content()' para interactuar con Gemini.\n"
          ]
        }
      ]
    },
    {
      "cell_type": "markdown",
      "source": [
        "# 2. Retrieval\n",
        "2.1 Cargo el corpus de 20 News Groups"
      ],
      "metadata": {
        "id": "1IDg0fvKAcnP"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "from sklearn.datasets import fetch_20newsgroups\n",
        "import pandas as pd\n",
        "\n",
        "newsgroups = fetch_20newsgroups(subset='train', remove=('headers', 'footers', 'quotes'))\n",
        "\n",
        "df_20news = pd.DataFrame({\n",
        "    \"text\": newsgroups.data,\n",
        "    \"target\": newsgroups.target,\n",
        "    \"target_name\": [newsgroups.target_names[t] for t in newsgroups.target]\n",
        "})\n",
        "\n",
        "# --- Reducción del corpus a 100 documentos balanceados por categoría ---\n",
        "N_POR_CATEGORIA = 5  # 5 docs x 20 categorías = 100 documentos\n",
        "df_20news = (\n",
        "    df_20news.groupby(\"target_name\", group_keys=False)\n",
        "    .apply(lambda x: x.sample(n=min(len(x), N_POR_CATEGORIA), random_state=42))\n",
        "    .reset_index(drop=True)\n",
        ")\n",
        "print(f\"Documentos en la muestra: {len(df_20news)}\")\n",
        "print(df_20news[\"target_name\"].value_counts())\n",
        "# --- fin reducción ---\n",
        "\n",
        "# Preprocesamiento\n",
        "df_20news[\"preprocessed_text\"] = df_20news[\"text\"].apply(preprocess_text)\n",
        "\n",
        "# Quitar documentos vacíos ANTES de generar embeddings (mantiene alineación)\n",
        "df_20news = df_20news[df_20news[\"preprocessed_text\"].str.strip().astype(bool)].reset_index(drop=True)\n",
        "print(f\"Documentos después de quitar vacíos: {len(df_20news)}\")\n",
        "\n",
        "df_20news.head()"
      ],
