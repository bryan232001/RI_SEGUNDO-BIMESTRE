        "2.3 Creo una query y hago la búsqueda"
      ],
      "metadata": {
        "id": "O1g3hIEIAtYt"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "from sklearn.metrics.pairwise import cosine_similarity\n",
        "import numpy as np\n",
        "\n",
        "# 1. Definir una query\n",
        "query_text_gemini = \"computación gráfica e inteligencia artificial\"\n",
        "print(f\"\\n🔍 Query original: '{query_text_gemini}'\")\n",
        "\n",
        "# 2. Preprocesar la query con la misma función utilizada para el corpus\n",
        "query_preprocessed = preprocess_text(query_text_gemini)\n",
        "print(f\"   Query preprocesada: '{query_preprocessed}'\")\n",
        "\n",
        "# 3. Generar el embedding de la query usando el modelo de Gemini\n",
        "print(\"\\n⏳ Generando embedding para la query...\")\n",
        "query_embedding_response = genai.embed_content(\n",
        "    model=EMBEDDING_MODEL_NAME,\n",
        "    content=[query_preprocessed], # content espera una lista de strings\n",
        "    task_type=\"RETRIEVAL_QUERY\",\n",
        "    output_dimensionality=768 # Asegurarse de que la dimensión coincide con los embeddings del corpus\n",
        ")\n",
        "query_embedding = np.array(query_embedding_response['embedding'][0])\n",
        "print(\"✅ Embedding de la query generado.\")\n",
        "\n",
        "# Asegurarse de que el embedding de la query esté en la misma forma que los embeddings del corpus\n",
        "# (1, num_dimensions) para cosine_similarity\n",
        "query_embedding = query_embedding.reshape(1, -1);\n",
        "\n",
        "# 4. Calcular la similitud coseno entre el embedding de la query y todos los embeddings del corpus\n",
        "print(\"\\n⏳ Calculando similitudes...\")\n",
        "similarities = cosine_similarity(query_embedding, embeddings_20news)[0]\n",
        "\n",
        "# 5. Obtener los índices de los 5 documentos más similares\n",
        "top_n = 5\n",
        "top_indices = np.argsort(similarities)[::-1][:top_n]\n",
        "\n",
        "print(\"✅ Búsqueda completada. Documentos más similares:\")\n",
        "\n",
        "# 6. Mostrar los resultados\n",
        "results_df = df_20news.iloc[top_indices].copy()\n",
        "results_df[\"Similitud\"] = similarities[top_indices]\n",
        "# Usar 'target_name' para el DataFrame df_20news\n",
        "results_df = results_df[[\"target_name\", \"text\", \"Similitud\"]]\n",
        "\n",
        "# Ajustar visualización del texto para que no sea demasiado largo\n",
        "results_df[\"text\"] = results_df[\"text\"].apply(lambda x: x[:300].replace('\\n', ' ') + \"...\")\n",
        "\n",
        "# display(\n",
        "#     results_df.style\n",
        "#         .format({\"Similitud\": \"{:.4f}\"})\n",
        "#         .set_caption(f\"Top {top_n} documentos más similares a la query: '{query_text_gemini}'\")\n",
        "#         .set_table_styles([\n",
